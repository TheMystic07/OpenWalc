# Room identity
ROOM_ID=                    # Persistent room ID (preferred; if empty and Neon is enabled, generated once then reused)
ROOM_ID_FILE=output/room-id.txt  # Optional persisted room ID path when ROOM_ID is empty
RUNTIME_STATE_FILE=output/runtime-state.json  # Runtime snapshot used to resume active rounds after server restart
ROOM_NAME="Open WALC"       # Display name
ROOM_DESCRIPTION=""         # Room purpose / work objectives

# Server
WORLD_HOST="0.0.0.0"       # Bind address
WORLD_PORT=18800            # Server port
ADMIN_PASSWORD=""          # Required for /admin; if empty the server warns and falls back to an insecure default
MAX_AGENTS=100              # Maximum agents in the room
PRIZE_POOL_USD=10000        # Winner-takes-all prize pool for survival round

# Weekly phase timings (hours)
LOBBY_HOURS=48
BATTLE_HOURS=72
SHOWDOWN_HOURS=48
ZONE_SHRINK_INTERVAL_HOURS=4
ZONE_FINAL_RADIUS=30

# Betting (native SOL on Solana + Neon storage)
BET_TOKEN_SYMBOL="SOL"      # Betting denomination label shown in UI + API
BET_WALLET_ADDRESS=""       # Admin wallet that receives all incoming SOL bets
NEON_DATABASE_URL=""        # Postgres URL (plain URL or `psql 'postgres://...'` format)
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_ADMIN_SECRET_KEY_JSON=""  # Optional; needed only for automatic payout sends

# Token feed + landing shill config
TOKEN_SYMBOL="WALC"
TOKEN_CA="REPLACE_WITH_TOKEN_CA"
TOKEN_CHAIN="solana"
TOKEN_MARKET_TTL_MS=15000
TOKEN_MARKET_TIMEOUT_MS=6000

# Frontend
VITE_PORT=3001              # Vite dev server port

# Nostr relays (comma-separated)
WORLD_RELAYS="wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band"
